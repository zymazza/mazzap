{
  "pipeline": [
    {
      "type": "readers.las",
      "filename": "/home/zy/Mazzap/Raw Data Inputs/lidar_input.laz"
    },
    {
      "type": "filters.elm"
    },
    {
      "type": "filters.range",
      "limits": "Classification![7:7]"
    },
    {
      "type": "filters.assign",
      "value": "Classification = 1"
    },
    {
      "type": "filters.smrf",
      "slope": 0.2,
      "window": 16,
      "threshold": 0.45,
      "scalar": 1.25
    },
    {
      "type": "filters.range",
      "limits": "Classification[2:2]"
    },
    {
      "type": "writers.gdal",
      "filename": "/home/zy/Mazzap/Processed Data/dem.tif",
      "gdaldriver": "GTiff",
      "resolution": 1,
      "output_type": "mean",
      "window_size": 8,
      "data_type": "float32",
      "nodata": -9999
    }
  ]
}
