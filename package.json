{
  "name": "mazzap",
  "version": "2.0.0",
  "description": "Mazzap v2 — a standalone, region-agnostic georeferenced 3D digital-twin engine.",
  "private": true,
  "main": "server.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zymazza/mazzap.git"
  },
  "homepage": "https://github.com/zymazza/mazzap#readme",
  "bugs": {
    "url": "https://github.com/zymazza/mazzap/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "init": "node scripts/init.js",
    "start": "node server.js",
    "start:local": "scripts/start-local-integrated.sh",
    "start:local:server": "CHAT_PROVIDER=ollama OLLAMA_HOST=http://127.0.0.1:11434 OLLAMA_MODEL=gpt-oss:20b OLLAMA_NUM_CTX=98304 VEIL_OPEN_BROWSER=0 scripts/start-local-integrated.sh",
    "add-layer": "python3 scripts/add_layer.py",
    "ingest-dem": "python3 scripts/ingest_dem.py",
    "ingest-imagery": "python3 scripts/ingest_imagery.py",
    "build-from-aoi": "python3 scripts/build_from_aoi.py",
    "fetch-landfire": "python3 packs/us-national/fetch_landfire.py",
    "fetch-wrc": "python3 packs/us-national/fetch_wrc.py",
    "fetch-forest-ecology": "python3 scripts/fetch_forest_ecology.py",
    "fetch-gssurgo": "python3 scripts/fetch_gssurgo.py",
    "fetch-climate-forcing": "python3 packs/us-national/fetch_climate_forcing.py",
    "derive-et0": "python3 scripts/derive_et0_daily.py",
    "et-water-balance": "python3 scripts/et_water_balance.py",
    "fetch-gridmet": "python3 packs/us-national/fetch_gridmet_forcing.py",
    "fetch-national-layers": "python3 scripts/fetch_national_layers.py",
    "ingest-manual-layers": "python3 scripts/ingest_manual_layers.py",
    "demo": "python3 scripts/build_from_aoi.py --aoi packs/us-national/demo/flatirons_aoi.shp --data-dir twins/demo/data --name 'Flatirons demo' --force",
    "serve-demo": "TWIN_DATA_DIR=twins/demo/data PORT=4174 node server.js",
    "build-vegetation": "python3 scripts/analyze_vegetation.py && python3 scripts/build_surrounding_vegetation.py",
    "build-survey-package": "python3 scripts/build_survey_package.py",
    "analyze-hydrology": "python3 scripts/analyze_hydrology.py",
    "analyze-fuels": "python3 scripts/analyze_fuels.py",
    "hydro-scenario": "python3 scripts/hydro_scenario.py",
    "fetch-distant-terrain": "python3 scripts/fetch_distant_terrain.py",
    "analyze-viewshed": "python3 scripts/analyze_viewshed.py",
    "fire-scenario": "python3 scripts/fire_scenario.py",
    "migrate": "python3 scripts/migrate_to_store.py",
    "export": "python3 scripts/export_viewer_payloads.py",
    "rebuild-store": "python3 scripts/rebuild_store.py",
    "canopy-history": "python3 scripts/canopy_density.py",
    "build-test-fixture": "python3 scripts/build_test_fixture.py",
    "test": "TWIN_DATA_DIR=tests/fixtures/mini-twin/data python3 scripts/twin_query_test.py",
    "test:demo": "TWIN_DATA_DIR=twins/demo/data python3 scripts/twin_query_test.py"
  },
  "author": "Zy Mazza",
  "license": "MIT"
}
