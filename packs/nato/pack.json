{
  "name": "nato",
  "title": "NATO regional adapter pack",
  "description": "A per-country acquisition and interpretation pack for NATO member states. The engine stays region-agnostic; this pack chooses country-specific source adapters, shared forest leaf-type sources, vegetation knowledge, and layer styling. The Netherlands adapter is implemented with AHN LiDAR elevation, PDOK aerial imagery, and Copernicus HRL Dominant Leaf Type for tree typing; registered countries without a national adapter build through explicit global/continental fallback sources.",
  "coverage": "NATO member states; national Tier-A path for the Netherlands (NLD/NL), global fallback for registered members without national adapters, and EEA/CLMS continental enrichment where available.",
  "hooks": {
    "vegetation": "vegetation.py",
    "layers": "layers.py"
  },
  "fetch_scripts": [
    "fetch_nato.py"
  ],
